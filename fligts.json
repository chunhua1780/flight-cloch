import requests
from ics import Calendar
import json

url = "https://p206-caldav.icloud.com/published/2/XXXXXXXX.ics"

r = requests.get(url, timeout=20)
text = r.text

print("STATUS:", r.status_code)
print("RAW HEAD:", text[:200])

flights = []
status = "ok"

try:
    if "BEGIN:VCALENDAR" not in text:
        raise Exception("Not ICS")

    cal = Calendar(text)

    events = list(cal.events)
    print("EVENT COUNT:", len(events))

    if len(events) == 0:
        status = "empty"

    for e in events:
        flights.append({
            "title": e.name,
            "start": str(e.begin),
            "end": str(e.end)
        })

except Exception as e:
    print("ERROR:", str(e))
    status = "error"

# 🧠 强制结构输出（关键修复）
output = {
    "status": status,
    "count": len(flights),
    "flights": flights
}

with open("flights.json", "w") as f:
    json.dump(output, f, indent=2)

print("FINAL COUNT:", len(flights))
